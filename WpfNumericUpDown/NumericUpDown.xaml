<UserControl x:Class="WpfNumericUpDown.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="24" MinWidth="60">
    <UserControl.Resources>
        <Style x:Key="SpinButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Delay" Value="400"/>
            <Setter Property="Interval" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DEE2E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CED4DA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="OuterBorder"
            BorderBrush="#ADADAD" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="ValueTextBox"
                     Grid.Column="0"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     Padding="4,2"
                     Background="Transparent"
                     LostFocus="ValueTextBox_LostFocus"
                     KeyDown="ValueTextBox_KeyDown"
                     GotKeyboardFocus="ValueTextBox_GotKeyboardFocus"
                     PreviewMouseLeftButtonDown="ValueTextBox_PreviewMouseLeftButtonDown"/>

            <Grid Grid.Column="1" Background="#F5F5F5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Left border separating text area from spin buttons -->
                <Rectangle Grid.RowSpan="2" Width="1" HorizontalAlignment="Left" Fill="#ADADAD"/>

                <RepeatButton x:Name="UpButton" Grid.Row="0"
                              Style="{StaticResource SpinButtonStyle}"
                              Click="UpButton_Click">
                    <Path Data="M 0,4 L 3.5,0 L 7,4"
                          Stroke="#444" StrokeThickness="1.5" StrokeLineJoin="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                </RepeatButton>

                <!-- Divider between up and down buttons -->
                <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Top" Fill="#ADADAD"/>

                <RepeatButton x:Name="DownButton" Grid.Row="1"
                              Style="{StaticResource SpinButtonStyle}"
                              Click="DownButton_Click">
                    <Path Data="M 0,0 L 3.5,4 L 7,0"
                          Stroke="#444" StrokeThickness="1.5" StrokeLineJoin="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                </RepeatButton>
            </Grid>
        </Grid>
    </Border>
</UserControl>
