<Window x:Class="SimpleWpfPropertyGrid.PropertyGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimpleWpfPropertyGrid"
        Width="500" Height="420" MinWidth="340" MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Type info banner -->
        <Border Grid.Row="0" Background="#34495E" Padding="10,5">
            <TextBlock x:Name="TypeInfoText"
                       Foreground="#BDC3C7"
                       FontSize="11"
                       FontStyle="Italic"
                       VerticalAlignment="Center"/>
        </Border>

        <local:PropertyGrid x:Name="PropertyGridControl" Grid.Row="1" Margin="8"/>

        <Border Grid.Row="2"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                Background="#F5F5F5" Padding="8">
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    Padding="24,5"
                    MinWidth="80"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Border>
    </Grid>
</Window>
