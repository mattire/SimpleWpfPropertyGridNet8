<Window x:Class="SimpleWpfPropertyGrid.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:pg="clr-namespace:SimpleWpfPropertyGrid;assembly=SimpleWpfPropertyGrid"
        mc:Ignorable="d"
        Title="WPF Property Grid Demo" Height="560" Width="580"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="WPF Property Grid"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SubtitleText"
                               Foreground="#BDC3C7" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Reset to Defaults"
                        VerticalAlignment="Center"
                        Padding="12,4"
                        Click="Reset_Click"
                        Background="#3D5266" Foreground="White"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Property Grid -->
        <pg:PropertyGrid x:Name="MainPropertyGrid" Grid.Row="1" Margin="10"/>

        <!-- Footer toolbar -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Background="#F8F9FA">
            <DockPanel Margin="10,6">
                <TextBlock x:Name="FooterHint"
                           Text="Click 'Open' on any object property to drill into it and edit recursively."
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#6C757D" FontSize="11"
                           FontStyle="Italic"/>
                <Button Content="Show Summary"
                        DockPanel.Dock="Right"
                        Padding="16,5"
                        Margin="0"
                        Click="ShowSummary_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
