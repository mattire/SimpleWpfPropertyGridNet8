<Window x:Class="WpfCollectionEditor.CollectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Collection Editor"
        Width="480" Height="500"
        MinWidth="320" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4,12,4"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>
    </Window.Resources>
    <DockPanel Margin="12">
        <Border DockPanel.Dock="Top"
                Background="#EFF3FF"
                BorderBrush="#C0CAEE"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6,10,6"
                Margin="0,0,0,10">
            <TextBlock x:Name="BannerText"
                       FontStyle="Italic"
                       Foreground="#3A4A8C"
                       FontSize="13"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Remove Selected" Click="RemoveButton_Click" Margin="0,0,8,0"/>
            <Button Content="Close" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>

        <GroupBox DockPanel.Dock="Bottom"
                  Header="Add Item"
                  Margin="0,10,0,0"
                  Padding="8,6,8,8">
            <StackPanel x:Name="AddControlsPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"/>
        </GroupBox>

        <ListBox x:Name="ItemsListBox"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
